-- Function to scan (SUDAH DIBENAH!)
local function scanCategory(category)
    resultBox.Text = "Scanning " .. category .. "..."
    task.wait(0.1)
   
    local results = {}
   
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
            local path = obj:GetFullName()
           
            -- FIX: string concatenation pake .. bukan +
            if #path > 100 then
                path = string.sub(path, 1, 100) .. "..."
            end
           
            local anchored = obj.Anchored and "YES" or "NO ❌"
            local locked = "Unknown"
            pcall(function() locked = obj.Locked and "YES" or "NO" end)
           
            local partString = string.format("[%s] %s\n📍 %s\n⚓ Anchored: %s\n---",
                obj.ClassName, obj.Name, path, anchored)
           
            -- Filter kategori
            if category == "vehicles" and (name:find("wheel") or name:find("car") or name:find("mobil") or name:find("tire") or name:find("ban")) then
                table.insert(results, partString)
            elseif category == "doors" and (name:find("door") or name:find("pintu") or name:find("gate")) then
                table.insert(results, partString)
            elseif category == "lights" and (name:find("light") or name:find("lamp") or name:find("lampu")) then
                table.insert(results, partString)
            elseif category == "seats" and (name:find("seat") or name:find("kursi") or name:find("chair")) then
                table.insert(results, partString)
            elseif category == "windows" and (name:find("window") or name:find("jendela")) then
                table.insert(results, partString)
            elseif category == "interactive" and (obj:IsA("MeshPart") or obj:IsA("UnionOperation")) then
                table.insert(results, partString)
            end
        end
    end
   
    if #results > 0 then
        local output = string.format("=== %s (%d found) ===\n\n", string.upper(category), #results)
        for i = 1, math.min(20, #results) do
            output = output .. results[i] .. "\n\n"
        end
        if #results > 20 then
            output = output .. string.format("\n... and %d more parts", #results - 20)
        end
        resultBox.Text = output
    else
        resultBox.Text = string.format("❌ No %s found in workspace", category)
    end
end

