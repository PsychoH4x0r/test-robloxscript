-- PART 4: FORCE FUNCTION (buat manipulasi part)
-- =============================================
local function forcePart(part)
    if not part or not part:IsA("BasePart") then return end
    
    -- Bersihin constraints lama
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("BodyMover") or child:IsA("Constraint") or 
           child:IsA("AlignPosition") or child:IsA("Torque") then
            child:Destroy()
        end
    end
    
    -- Set properties
    part.Anchored = false
    part.CanCollide = true
    
    -- Tambah constraints baru
    local torque = Instance.new("Torque", part)
    torque.Torque = Vector3.new(100000, 100000, 100000)
    
    local align = Instance.new("AlignPosition", part)
    local attachment2 = Instance.new("Attachment", part)
    
    torque.Attachment0 = attachment2
    align.MaxForce = 9e9
    align.MaxVelocity = math.huge
    align.Responsiveness = 200
    align.Attachment0 = attachment2
    align.Attachment1 = Attachment1
end

-- Apply force ke semua part yang anchored false
local function applyForceToAll()
    local count = 0
    for category, parts in pairs(Parts) do
        for _, part in ipairs(parts) do
            if part and part.Parent and not part.Anchored then
                forcePart(part)
                count = count + 1
            end
        end
    end
    showNotification("✅ FORCE APPLIED", count .. " parts siap dimanipulasi", 3, true)
end

