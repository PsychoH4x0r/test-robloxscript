        if lockMode == "None" and Mouse.Target then
            lockedPart = Mouse.Target
            lockMode = "Part"
            forcePart(lockedPart)
            showNotification("🔒 PART LOCKED", "Locked to: " .. lockedPart.Name, 2, true)
        else
            lockMode = "None"
            lockedPart = nil
            showNotification("🔓 UNLOCKED", "Part released", 2)
        end
    end
    
    -- E = manual position (cursor)
    if input.KeyCode == Enum.KeyCode.E then
        lockMode = "Cursor"
        lockedPart = nil
        showNotification("📍 MANUAL MODE", "Following cursor", 2)
    end
end)

