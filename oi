        scanCategory(cat)
    end)
end

-- Scan All
scanBtn.MouseButton1Click:Connect(function()
    resultBox.Text = "Scanning all categories...\n"
   
    for cat, _ in pairs(partsData) do
        partsData[cat] = {}
    end
   
    local total = 0
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
           
            if name:find("wheel") or name:find("car") or name:find("mobil") then
                table.insert(partsData.vehicles, obj.Name)
                total += 1
            elseif name:find("door") or name:find("pintu") then
                table.insert(partsData.doors, obj.Name)
                total += 1
            elseif name:find("light") or name:find("lamp") then
                table.insert(partsData.lights, obj.Name)
                total += 1
            elseif name:find("seat") or name:find("kursi") then
                table.insert(partsData.seats, obj.Name)
                total += 1
            elseif name:find("window") or name:find("jendela") then
                table.insert(partsData.windows, obj.Name)
                total += 1
            elseif obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                table.insert(partsData.interactive, obj.Name)
                total += 1
            end
        end
    end
   
    local summary = string.format("✅ SCAN COMPLETE!\n\nTotal parts found: %d\n\n", total)
    summary = summary .. string.format("🚗 Vehicles: %d\n", #partsData.vehicles)
    summary = summary .. string.format("🚪 Doors: %d\n", #partsData.doors)
    summary = summary .. string.format("💡 Lights: %d\n", #partsData.lights)
    summary = summary .. string.format("🪑 Seats: %d\n", #partsData.seats)
    summary = summary .. string.format("🪟 Windows: %d\n", #partsData.windows)
    summary = summary .. string.format("🎮 Interactive: %d\n\n", #partsData.interactive)
    summary = summary .. "Click category buttons above to see details!"
   
    resultBox.Text = summary
end)

