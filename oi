    -- Reset
    for category, _ in pairs(Parts) do
        Parts[category] = {}
    end
    totalParts = 0
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
            local path = obj:GetFullName():lower()
            local class = obj.ClassName
            local anchored = obj.Anchored
            
            -- DOORS (480)
            if name:find("door") or name:find("pintu") or name:find("gate") or name:find("cubdoors") then
                table.insert(Parts.doors, obj)
                totalParts = totalParts + 1
            
            -- WINDOWS (227)
            elseif name:find("window") or name:find("jendela") or name:find("storewindow") then
                table.insert(Parts.windows, obj)
                totalParts = totalParts + 1
            
            -- SEATS (940)
            elseif obj:IsA("Seat") or obj:IsA("VehicleSeat") or name:find("seat") or name:find("kursi") or name:find("chair") then
                table.insert(Parts.seats, obj)
                totalParts = totalParts + 1
            
            -- RIGS / MANNEQUIN (9063 interactive)
            elseif path:find("characterdisplays") or path:find("rig") or 
                   name:find("head") or name:find("torso") or name:find("arm") or 
                   name:find("leg") or name:find("hand") or name:find("foot") then
                table.insert(Parts.rigs, obj)
                totalParts = totalParts + 1
            
            -- CREDIT CARDS
            elseif name:find("credit") or name:find("card") or path:find("creditcardreaders") then
                table.insert(Parts.creditCards, obj)
                totalParts = totalParts + 1
            
            -- CARWASH
            elseif path:find("carwash") or name:find("soap") then
                table.insert(Parts.carwash, obj)
                totalParts = totalParts + 1
            
            -- TOOLS
            elseif path:find("tools") or name:find("key") or name:find("carry") then
                table.insert(Parts.tools, obj)
                totalParts = totalParts + 1
            
            -- JOB GIVERS
            elseif path:find("jobgivers") or name:find("bank") or name:find("day care") then
                table.insert(Parts.jobGivers, obj)
                totalParts = totalParts + 1
            
            -- LIGHTS
            elseif name:find("light") or name:find("lamp") or name:find("lampu") then
                table.insert(Parts.lights, obj)
                totalParts = totalParts + 1
            end
        end
    end
    
    return Parts
end

